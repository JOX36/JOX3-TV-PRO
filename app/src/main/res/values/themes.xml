<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.StreamVault" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/dark_background</item>
    </style>

    <style name="Theme.StreamVault.TV" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/dark_background</item>
    </style>

    <style name="Theme.StreamVault.Player" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <color name="cyan_primary">#FF00E5FF</color>
    <color name="electric_blue">#FF2979FF</color>
    <color name="dark_background">#FF060E1A</color>
    <color name="dark_surface">#FF0A1628</color>
    <color name="text_primary">#FFFFFFFF</color>
    <color name="text_secondary">#FFB0BEC5</color>
</resources>
